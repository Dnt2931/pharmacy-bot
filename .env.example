# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your pharmacy's Telegram Chat ID (use @userinfobot to find it)
PHARMACY_CHAT_ID=your_pharmacy_chat_id

# URL where your webapp/index.html is hosted (GitHub Pages / Vercel / Netlify)
WEBAPP_URL=https://your-webapp-url.com

# Database (leave as sqlite for local, or use PostgreSQL URL for production)
DATABASE_URL=sqlite:///./pharmacy.db
# DATABASE_URL=postgresql://user:password@localhost/pharmacydb
